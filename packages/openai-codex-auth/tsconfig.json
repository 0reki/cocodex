{
  "compilerOptions": {
    "target": "ES2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "allowJs": false,
    "paths": {
      "@workspace/openai-signup/env": ["../openai-signup/src/env.ts"],
      "@workspace/openai-signup/internal/*": ["../openai-signup/src/internal/*"],
      "@workspace/openai-signup/sdk": ["../openai-signup/src/sdk.ts"]
    },
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*", "scripts/**/*"],
  "exclude": ["node_modules"]
}
