{
  "name": "cocodex",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "bunx --bun turbo run build",
    "dev": "bunx --bun turbo run dev",
    "start": "bunx --bun turbo run start --filter=backend --filter=web",
    "lint": "bunx --bun turbo run lint",
    "lint:fix": "bunx --bun turbo run lint -- --fix",
    "lint:prettier": "bunx --bun prettier --check .",
    "typecheck": "bunx --bun turbo run typecheck",
    "format": "bunx --bun prettier --write .",
    "format:check": "bunx --bun prettier --check .",
    "docker:up": "docker compose --env-file .env.docker up --build",
    "docker:down": "docker compose down",
    "commit": "git-cz",
    "commitlint": "bunx commitlint --edit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.1",
    "typescript": "5.9.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/node": "^25.5.0",
    "i18n-iso-countries": "^7.14.0"
  }
}
